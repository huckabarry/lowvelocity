<?xml version="1.0" encoding="UTF-8"?>
<rss xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:atom="http://www.w3.org/2005/Atom" version="2.0" xmlns:media="http://search.yahoo.com/mrss/">
    <channel>
        <title><![CDATA[{{@site.title}}]]></title>
        <description><![CDATA[{{@site.description}}]]></description>
        <link>{{@site.url}}/</link>
        <image>
            <url>{{@site.url}}/favicon.png</url>
            <title>{{@site.title}}</title>
            <link>{{@site.url}}/</link>
        </image>
        <generator>Ghost</generator>
        <lastBuildDate>{{date format="ddd, DD MMM YYYY HH:mm:ss ZZ"}}</lastBuildDate>
        <atom:link href="{{@site.url}}/rss/" rel="self" type="application/rss+xml"/>
        <ttl>60</ttl>

        {{#get "posts" filter="tag:-[updates,status,note,notes,afterword,hash-bluesky,hash-atproto,listening,hash-crucialtracks,check-ins,hash-swarm,hash-foursquare,hash-popfeed,books,reading,movies,watching,shows]" limit="100" include="authors,tags" order="published_at desc" formats="html"}}
            {{#foreach posts}}
                <item>
                    <title><![CDATA[{{title}}]]></title>
                    <description><![CDATA[{{excerpt words="50"}}]]></description>
                    <link>{{url absolute="true"}}</link>
                    <guid isPermaLink="false">{{id}}</guid>
                    <pubDate>{{date published_at format="ddd, DD MMM YYYY HH:mm:ss ZZ"}}</pubDate>
                    {{#primary_author}}
                        <dc:creator><![CDATA[{{name}}]]></dc:creator>
                    {{/primary_author}}
                    {{#if feature_image}}
                        <media:content url="{{img_url feature_image absolute="true"}}" medium="image"/>
                    {{/if}}
                    {{#foreach tags}}
                        <category><![CDATA[{{name}}]]></category>
                    {{/foreach}}
                    <content:encoded><![CDATA[{{content}}]]></content:encoded>
                </item>
            {{/foreach}}
        {{/get}}
    </channel>
</rss>
