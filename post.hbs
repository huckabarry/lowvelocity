{{!< default}}

{{#post}}
<article class="{{post_class}} cactus-article">
    <header class="cactus-article-header">
        {{#has tag="afterword"}}
        {{else}}
            <h1 class="cactus-title cactus-article-title">{{title}}</h1>
        {{/has}}

        <div class="cactus-meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date published_at format="DD MMM YYYY"}}</time>
            <span aria-hidden="true">/</span>
            <span>{{reading_time}}</span>
            {{#if primary_tag}}
                <span aria-hidden="true">/</span>
                {{#primary_tag}}<a href="{{url}}">{{name}}</a>{{/primary_tag}}
            {{/if}}
        </div>

        {{#if custom_excerpt}}
            <p class="cactus-excerpt">{{custom_excerpt}}</p>
        {{/if}}

        {{#has tag="#crucialtracks"}}
        {{else}}
            {{> "feature-image"}}
        {{/has}}
    </header>

    <div class="cactus-content">
        {{content}}
    </div>

    {{#has tag="#crucialtracks"}}
        <script>
            (() => {
                const article = document.currentScript.closest(".tag-hash-crucialtracks");
                const content = article?.querySelector(".cactus-content");
                if (!content) return;

                content.querySelectorAll('a[href*="audio-ssl.itunes.apple.com"]').forEach((link) => {
                    if (link.dataset.audioEnhanced === "true") return;
                    link.dataset.audioEnhanced = "true";

                    const audioUrl = new URL(link.href);
                    audioUrl.searchParams.delete("ref");

                    const player = document.createElement("audio");
                    player.className = "lv-listening-audio";
                    player.controls = true;
                    player.preload = "none";
                    player.src = audioUrl.toString();
                    player.setAttribute("aria-label", "Preview audio");

                    link.insertAdjacentElement("beforebegin", player);
                    link.hidden = true;
                });
            })();
        </script>
    {{/has}}

    {{#if tags}}
        <footer class="post-tags">
            {{#foreach tags}}
                <a href="{{url}}">#{{name}}</a>
            {{/foreach}}
        </footer>
    {{/if}}
</article>

{{#if comments}}
    <section class="cactus-comments">
        {{comments mode="auto"}}
    </section>
{{/if}}

{{#if @custom.show_related_posts}}
    {{> "related-posts"}}
{{/if}}
{{/post}}
