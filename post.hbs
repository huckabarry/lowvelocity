{{!< default}}

{{#post}}
{{#has tag="check-ins"}}
    <link rel="stylesheet" href="{{asset "vendor/leaflet/leaflet.css"}}">
    <script src="{{asset "vendor/leaflet/leaflet.js"}}"></script>
{{/has}}

<article class="{{post_class}} cactus-article">
    <header class="cactus-article-header">
        {{#has tag="#crucialtracks"}}
            <h1 class="is-visually-hidden">{{title}}</h1>
        {{else has tag="afterword,#bluesky"}}
        {{else}}
            <h1 class="cactus-title cactus-article-title">{{title}}</h1>
        {{/has}}

        <div class="cactus-meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date published_at format="DD MMM YYYY"}}</time>
            {{#has tag="#crucialtracks"}}
            {{else}}
                <span aria-hidden="true">/</span>
                <span>{{reading_time}}</span>
            {{/has}}
            {{#if primary_tag}}
                <span aria-hidden="true">/</span>
                {{#has tag="#crucialtracks"}}
                    {{#primary_tag}}<a href="{{@site.url}}/listening/">{{name}}</a>{{/primary_tag}}
                {{else}}
                    {{#primary_tag}}<a href="{{url}}">{{name}}</a>{{/primary_tag}}
                {{/has}}
            {{/if}}
        </div>

        {{#has tag="#crucialtracks"}}
        {{else}}
            {{#if custom_excerpt}}
                <p class="cactus-excerpt">{{custom_excerpt}}</p>
            {{/if}}
        {{/has}}

        {{#has tag="#crucialtracks"}}
        {{else}}
            {{> "feature-image"}}
        {{/has}}
    </header>

    {{#has tag="#crucialtracks"}}
        <div class="cactus-content lv-listening-post" data-listening-preview>
            {{#if feature_image}}
                <figure class="lv-listening-entry__art lv-listening-post__art">
                    <button class="lv-listening-post__play" type="button" aria-label="{{t "Play preview"}}: {{title}}" data-listening-preview-toggle>
                        <img
                            srcset="{{img_url feature_image size="s"}} 300w,
                                    {{img_url feature_image size="m"}} 750w"
                            sizes="(min-width: 760px) 650px, calc(100vw - 2rem)"
                            src="{{img_url feature_image size="m"}}"
                            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
                        <span class="listening-ticker-icon" aria-hidden="true"></span>
                    </button>
                </figure>
            {{/if}}
            <div class="lv-listening-post__body">
                {{content}}
            </div>
        </div>
    {{else}}
        <div class="cactus-content">
            {{content}}
            {{#has tag="check-ins"}}
                <figure class="checkin-post-map-card">
                    <div class="checkins-map checkin-post-map" data-checkin-post-map aria-label="{{t "Map of this check-in"}}"></div>
                </figure>
            {{/has}}
        </div>
    {{/has}}

    {{#has tag="#bluesky"}}
        <section
            class="atproto-engagement"
            data-atproto-engagement
            data-atproto-endpoint="https://sync.lowvelocity.org/updates/bluesky/thread"
            data-atproto-rkey="{{slug}}"
            aria-label="{{t "Bluesky discussion"}}">
            <p class="atproto-engagement__status">{{t "Loading Bluesky discussion…"}}</p>
        </section>
    {{/has}}

    {{#if tags}}
        <footer class="post-tags">
            {{#foreach tags}}
                <a href="{{url}}">#{{name}}</a>
            {{/foreach}}
        </footer>
    {{/if}}
</article>

{{#if comments}}
    <section class="cactus-comments">
        {{#match @custom.color_scheme "Dark"}}
            {{comments mode="dark"}}
        {{else match @custom.color_scheme "Light"}}
            {{comments mode="light"}}
        {{else}}
            {{comments mode="auto"}}
        {{/match}}
        <script>
            (() => {
                const script = document.currentScript.previousElementSibling;
                if (!script || !script.matches("script[data-ghost-comments]")) return;
                const theme = document.documentElement.getAttribute("data-theme") === "light" ? "light" : "dark";
                script.setAttribute("data-color-scheme", theme);
            })();
        </script>
    </section>
{{/if}}

{{#if @custom.show_related_posts}}
    {{> "related-posts"}}
{{/if}}
{{/post}}
