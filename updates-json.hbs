{
    "version": "https://jsonfeed.org/version/1.1",
    "title": {{json title=(concat @site.title " — Updates")}},
    "home_page_url": {{json (concat @site.url "/updates/")}},
    "feed_url": {{json (concat @site.url "/updates/feed.json/")}},
    "description": "Status updates, listening notes, check-ins, books, movies, and shows folded into one running stream.",
    "items": [
        {{#get "posts" filter="tag:[hash-bluesky,hash-crucialtracks,check-ins,hash-popfeed]" limit="100" include="authors,tags" order="published_at desc" formats="html"}}
            {{#foreach posts}}
                {
                    "id": {{json id}},
                    "url": {{json (url absolute="true")}},
                    "date_published": {{json (date published_at format="YYYY-MM-DDTHH:mm:ss.SSSZ")}},
                    "summary": {{json (excerpt words="50")}},
                    "content_html": {{json html}},
                    "tags": [
                        {{#foreach tags}}
                            {{json name}}{{#unless @last}},{{/unless}}
                        {{/foreach}}
                    ]
                }{{#unless @last}},{{/unless}}
            {{/foreach}}
        {{/get}}
    ]
}
