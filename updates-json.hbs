{
    "version": "https://jsonfeed.org/version/1.1",
    "title": "{{@site.title}} — Updates",
    "home_page_url": "{{@site.url}}/updates/",
    "feed_url": "{{@site.url}}/updates/feed.json/",
    "description": "Status updates imported from Bluesky.",
    "items": [
        {{#get "posts" filter="tag:hash-bluesky" limit="100" include="authors,tags" order="published_at desc" formats="html"}}
            {{#foreach posts}}
                {
                    "id": {{json id}},
                    "url": "{{url absolute="true"}}",
                    "date_published": "{{date published_at format="YYYY-MM-DDTHH:mm:ss.SSSZ"}}",
                    "summary": "{{excerpt words="50"}}",
                    "content_html": {{json html}},
                    "tags": [
                        {{#foreach tags}}
                            {{json name}}{{#unless @last}},{{/unless}}
                        {{/foreach}}
                    ]
                }{{#unless @last}},{{/unless}}
            {{/foreach}}
        {{/get}}
    ]
}
