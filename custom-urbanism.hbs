{{!< default}}

<header class="archive-header">
    <h1 class="cactus-title">Urbanism</h1>
    <p>Planning, housing, transportation, public finance, and civic life.</p>
</header>

<section class="cactus-section archive-section">
    <ul class="post-list" role="list">
        {{#foreach posts}}
            {{> "post-preview"}}
        {{else}}
            <li>No urbanism posts are published yet.</li>
        {{/foreach}}
    </ul>
    {{pagination}}
</section>
