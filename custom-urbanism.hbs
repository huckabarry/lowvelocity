{{!< default}}

{{#contentFor "body_class"}} lowvelocity-section-template lowvelocity-urbanism-template{{/contentFor}}

<main class="site-main lowvelocity-section">

    <section class="lowvelocity-section-head gh-canvas">
        <p class="lowvelocity-section-kicker">Urbanism</p>
        <h1 class="lowvelocity-section-title">Urbanism</h1>
        <p class="lowvelocity-section-description">Planning, housing, transportation, public finance, and civic life.</p>
    </section>

    <div class="post-feed gh-feed gh-canvas">
        {{#foreach posts}}
            {{> "loop"}}
        {{else}}
            <p class="lowvelocity-empty">No urbanism posts are published yet.</p>
        {{/foreach}}
    </div>

    {{pagination}}

</main>
