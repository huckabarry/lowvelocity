{{!< default}}

<header class="archive-header">
    <h1 class="cactus-title">Field Notes</h1>
    <p>Travel, photography, urbanism, and notes from being out in the world.</p>
</header>

<section class="cactus-section archive-section">
    <ul class="post-list" role="list">
        {{#get "posts" filter="tag:[field-notes,urbanism,housing,transportation,public-finance]" limit="100" include="tags" order="published_at desc" as |field_notes|}}
            {{#foreach field_notes}}
                {{> "post-preview"}}
            {{else}}
                <li>No field notes are published yet.</li>
            {{/foreach}}
        {{/get}}
    </ul>
</section>
