{{!< default}}

<header class="archive-header">
    <h1 class="cactus-title">Field Notes</h1>
    <p>Travel, photography, urbanism, and notes from being out in the world.</p>
</header>

<section class="cactus-section archive-section">
    <ul class="post-list" role="list">
        {{#get "posts" filter="tag:[field-notes,urbanism,housing,transportation,public-finance]" limit="100" include="tags" order="published_at desc" as |field_notes|}}
            {{#foreach field_notes}}
                {{> "post-preview"}}
            {{else}}
                <li>No field notes are published yet.</li>
            {{/foreach}}
        {{/get}}
    </ul>
</section>

<section class="home-profile-card" aria-label="About the author">
    <a class="home-profile-card__identity" href="https://bsky.app/profile/bryan.eurosky.social" target="_blank" rel="me noopener noreferrer">
        {{#if @site.icon}}
            <img class="home-profile-card__avatar" src="{{@site.icon}}" alt="" loading="lazy">
        {{else}}
            <span class="home-profile-card__avatar home-profile-card__avatar--fallback" aria-hidden="true">BR</span>
        {{/if}}
        <span class="home-profile-card__text">
            <strong>Bryan Robb</strong>
            <span>@bryan.eurosky.social</span>
        </span>
    </a>

    <nav class="home-profile-card__links" aria-label="More from Bryan Robb">
        <a href="{{@site.url}}/posts/">Archive</a>
        <a href="{{@site.url}}/now/">Now</a>
        <a href="https://bsky.app/profile/bryan.eurosky.social" target="_blank" rel="me noopener noreferrer">Bluesky</a>
    </nav>
</section>
