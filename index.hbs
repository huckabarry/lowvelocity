{{!< default}}

<section class="home-intro">
    <h1 class="is-visually-hidden">{{@site.title}}</h1>
    {{#if @site.description}}
        <p>{{@site.description}}</p>
    {{else}}
        <p>Hi, I am a theme for Ghost, a simple Cactus-inspired home for essays, notes, photos, and quiet little dispatches.</p>
    {{/if}}
</section>

{{#get "posts" filter="featured:true+tag:-photos" limit="3" include="tags" as |featured_posts|}}
    {{#if featured_posts}}
        <section class="cactus-section">
            <h2 class="cactus-title cactus-title-small">{{t "Pinned Posts"}}</h2>
            <ul class="post-list" role="list">
                {{#foreach featured_posts}}
                    {{> "post-preview"}}
                {{/foreach}}
            </ul>
        </section>
    {{/if}}
{{/get}}

<section class="cactus-section">
    <h2 class="cactus-title cactus-title-link"><a href="{{@site.url}}/">{{t "Posts"}}</a></h2>
    {{#get "posts" filter="tag:-[status,note,notes,afterword,listening,hash-crucialtracks]" include="tags" limit=@config.posts_per_page as |home_posts home_pagination|}}
        <ul class="post-list" role="list">
            {{#foreach home_posts}}
                {{> "post-preview"}}
            {{/foreach}}
        </ul>
        {{#if home_pagination.next}}
            <p class="cactus-more-link"><a href="{{@site.url}}/page/{{home_pagination.next}}/">{{t "View more"}}</a></p>
        {{/if}}
    {{/get}}
</section>

{{#get "posts" filter="tag:hash-crucialtracks" limit="1" include="tags" order="published_at desc" as |latest_tracks|}}
    {{#if latest_tracks}}
        <section class="cactus-section listening-ticker-section">
            <h2 class="cactus-title cactus-title-link"><a href="{{@site.url}}/listening/">{{t "Listening"}}</a></h2>
            {{#foreach latest_tracks}}
                <a class="listening-ticker" href="{{url}}" aria-label="{{t "Latest listening post"}}: {{title}}">
                    {{#if feature_image}}
                        <img class="listening-ticker-art" src="{{img_url feature_image size="s"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
                    {{/if}}
                    <span class="listening-ticker-body">
                        <span class="listening-ticker-label">{{t "Last played"}}</span>
                        <span class="listening-ticker-window" aria-hidden="true">
                            <span class="listening-ticker-track">
                                <span>{{title}}</span>
                                <span>{{title}}</span>
                                <span>{{title}}</span>
                            </span>
                        </span>
                        <span class="is-visually-hidden">{{title}}</span>
                    </span>
                </a>
            {{/foreach}}
        </section>
    {{/if}}
{{/get}}

<section class="cactus-section status-section" data-bluesky-feed data-bluesky-handle="bryan.eurosky.social" data-bluesky-endpoint="https://sync.lowvelocity.org/updates/bluesky?source=bryan" data-bluesky-limit="25">
    <div class="status-section-head">
        <h2 class="cactus-title cactus-title-link">
            <a href="https://bsky.app/profile/bryan.eurosky.social" target="_blank" rel="noopener noreferrer">{{t "Updates"}}</a>
        </h2>
        <div class="status-controls" data-status-controls hidden>
            <button type="button" data-status-prev aria-label="{{t "Show previous update"}}">{{t "Back"}}</button>
            <span class="status-position" data-status-position aria-live="polite"></span>
            <button type="button" data-status-next aria-label="{{t "Show next update"}}">{{t "Next"}}</button>
        </div>
    </div>
    <div class="status-carousel" data-status-carousel aria-live="polite">
        <p class="bluesky-note-status">{{t "Loading updates…"}}</p>
    </div>
</section>
