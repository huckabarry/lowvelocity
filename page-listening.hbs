{{!< default}}

{{#post}}
<section class="photos-intro listening-intro">
    <h1 class="cactus-title">{{title}}</h1>
    {{#if custom_excerpt}}
        <p>{{custom_excerpt}}</p>
    {{/if}}
    <div class="cactus-content">
        {{content}}
    </div>
</section>
{{/post}}

<section class="cactus-section listening-archive">
    {{#get "posts" filter="tag:hash-crucialtracks" limit="100" include="tags" order="published_at desc" as |tracks|}}
        {{#if tracks}}
            <div class="listening-grid">
                {{#foreach tracks}}
                    <article class="listening-card">
                        <a class="listening-card-link" href="{{url}}">
                            {{#if feature_image}}
                                <img class="listening-card-art" src="{{img_url feature_image size="m"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
                            {{/if}}
                            <span class="listening-card-date">{{date published_at format="DD MMM YYYY"}}</span>
                            <h2>{{title}}</h2>
                        </a>
                    </article>
                {{/foreach}}
            </div>
        {{else}}
            <p>No listening posts are available yet.</p>
        {{/if}}
    {{/get}}
</section>
