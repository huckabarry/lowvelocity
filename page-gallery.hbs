{{!< default}}

{{#post}}
<section class="photos-intro">
    <h1 class="cactus-title">{{title}}</h1>
    {{#if custom_excerpt}}
        <p>{{custom_excerpt}}</p>
    {{/if}}
    <div class="cactus-content">
        {{content}}
    </div>
</section>
{{/post}}

<section class="photo-section">
    <div class="photo-feed">
        <div class="grid-item grid-sizer"></div>
        {{#get "posts" filter="tag:[photos,gallery,photography]" limit="100" include="tags" as |gallery_posts|}}
            {{#foreach gallery_posts}}
                {{> "photo-card"}}
            {{/foreach}}
        {{/get}}
    </div>
</section>
