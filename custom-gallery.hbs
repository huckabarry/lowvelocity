{{!< default}}

{{#contentFor "body_class"}} afterword-section-template afterword-gallery-template{{/contentFor}}

<main class="site-main afterword-section afterword-gallery">

    <section class="afterword-section-head gh-canvas">
        <p class="afterword-section-kicker">Gallery</p>
        <h1 class="afterword-section-title">Gallery</h1>
        <p class="afterword-section-description">A visual archive of image-forward posts and photo essays.</p>
    </section>

    <section class="afterword-gallery-grid gh-canvas" aria-label="Gallery posts">
        {{#foreach posts}}
            <article class="afterword-gallery-card {{post_class}}">
                <a class="afterword-gallery-link" href="{{url}}" aria-label="{{title}}">
                    {{#if feature_image}}
                        <img
                            class="afterword-gallery-image"
                            srcset="{{img_url feature_image size="s"}} 400w,
                                    {{img_url feature_image size="m"}} 750w,
                                    {{img_url feature_image size="l"}} 960w"
                            sizes="(max-width: 640px) 100vw, (max-width: 960px) 50vw, 33vw"
                            src="{{img_url feature_image size="m"}}"
                            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                            loading="lazy"
                        >
                    {{else}}
                        <span class="afterword-gallery-placeholder">{{title}}</span>
                    {{/if}}
                    <span class="afterword-gallery-caption">
                        <span class="afterword-gallery-title">{{title}}</span>
                        <time class="afterword-gallery-date" datetime="{{date format="YYYY-MM-DD"}}">{{date published_at format="DD MMM YYYY"}}</time>
                    </span>
                </a>
            </article>
        {{else}}
            <p class="afterword-empty">No gallery posts are published yet.</p>
        {{/foreach}}
    </section>

    {{pagination}}

</main>
