{{!< default}}

<header class="photos-intro">
    <h1 class="cactus-title">Gallery</h1>
    <p>A visual archive of image-forward posts and photo essays.</p>
</header>

<section class="photo-section">
    <div class="photo-feed">
        <div class="grid-item grid-sizer"></div>
        {{#get "posts" filter="tag:[gallery,hash-gallery,photography,hash-photography]" limit="100" include="tags" order="published_at desc" formats="html" as |gallery_posts|}}
            {{#foreach gallery_posts}}
                {{#has tag="gallery"}}
                    {{> "photo-card"}}
                {{else}}
                    {{#has tag="#gallery"}}
                        {{> "photo-card"}}
                    {{/has}}
                {{/has}}
                {{> "photo-body-source"}}
            {{else}}
                <p>No gallery posts are published yet.</p>
            {{/foreach}}
        {{/get}}
    </div>
</section>
