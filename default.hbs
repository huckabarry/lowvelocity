<!DOCTYPE html>
<html lang="{{@site.locale}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title page=(t " (Page %)")}}</title>
    <script>
        (function () {
            var configuredTheme = '{{@custom.color_scheme}}'.toLowerCase();
            var storedTheme = localStorage.getItem('cactus-theme');
            var preferredTheme = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
            var defaultTheme = configuredTheme === 'light' || configuredTheme === 'dark' ? configuredTheme : preferredTheme;
            document.documentElement.setAttribute('data-theme', storedTheme || defaultTheme);
        })();
    </script>
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    {{#is "home"}}
        <link rel="site.standard.publication" href="at://did:plc:peshyp24p4yyoaz3zdsppp3e/site.standard.publication/3mgwfts634r2z">
    {{/is}}
    <style>
        :root {
            --space-shell: min(calc(100% - 2rem), {{@custom.content_width}});
            --header-font-weight: {{#match @custom.header_font_weight "Regular"}}400{{else match @custom.header_font_weight "Medium"}}500{{else match @custom.header_font_weight "Semibold"}}600{{else match @custom.header_font_weight "Bold"}}800{{else match @custom.header_font_weight "Extra Bold"}}900{{else match @custom.header_font_weight "Black"}}900{{else}}800{{/match}};
            --header-font-stroke: {{#match @custom.header_font_weight "Black"}}0.2px{{else}}0{{/match}};
            --navigation-font-weight: {{#match @custom.navigation_font_weight "Regular"}}400{{else match @custom.navigation_font_weight "Semibold"}}600{{else match @custom.navigation_font_weight "Bold"}}700{{else}}500{{/match}};
            --font-body: {{#match @custom.body_font "IBM Plex Mono"}}"IBM Plex Mono", monospace{{else match @custom.body_font "Roboto Mono"}}"Roboto Mono", monospace{{else}}var(--gh-font-body, var(--font-mono)){{/match}};
            --body-font-style: {{#match @custom.body_font_style "Italic"}}italic{{else}}normal{{/match}};
            --color-accent: {{@site.accent_color}};
            --color-link: {{@site.accent_color}};
            --color-quote: {{@site.accent_color}};
        }

        html[data-theme="light"] {
            --color-global-bg: {{@custom.light_mode_background_color}};
            --color-global-text: {{@custom.light_mode_text_color}};
            --color-accent-2: {{@custom.light_mode_text_color}};
            {{#if @custom.use_separate_mode_accent_colors}}
            --color-accent: {{@custom.light_mode_accent_color}};
            --color-link: {{@custom.light_mode_accent_color}};
            --color-quote: {{@custom.light_mode_accent_color}};
            {{/if}}
        }

        html[data-theme="dark"] {
            --color-global-bg: {{@custom.dark_mode_background_color}};
            --color-global-text: {{@custom.dark_mode_text_color}};
            --color-accent-2: {{@custom.dark_mode_text_color}};
            {{#if @custom.use_separate_mode_accent_colors}}
            --color-accent: {{@custom.dark_mode_accent_color}};
            --color-link: {{@custom.dark_mode_accent_color}};
            --color-quote: {{@custom.dark_mode_accent_color}};
            {{/if}}
        }
    </style>
    {{ghost_head}}
    <style id="lowvelocity-card-overrides">
        .cactus-content .kg-bookmark-card a.kg-bookmark-container,
        .cactus-content .kg-bookmark-card a.kg-bookmark-container:hover,
        .kg-bookmark-card.lv-atproto-card a.kg-bookmark-container,
        .kg-bookmark-card.lv-atproto-card a.kg-bookmark-container:hover,
        .now-status-entry__body .kg-bookmark-card a.kg-bookmark-container,
        .now-status-entry__body .kg-bookmark-card a.kg-bookmark-container:hover {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(6rem, 34%);
            gap: 0.75rem;
            align-items: stretch;
            padding: 0.8rem;
            overflow: hidden;
            border: 1px dashed var(--color-rule);
            border-radius: 0.55rem;
            background: transparent;
            box-shadow: none;
            color: var(--color-global-text);
            opacity: 1;
            text-decoration: none;
        }

        .cactus-content .kg-bookmark-card a.kg-bookmark-container:hover,
        .kg-bookmark-card.lv-atproto-card a.kg-bookmark-container:hover,
        .now-status-entry__body .kg-bookmark-card a.kg-bookmark-container:hover {
            border-color: var(--color-accent);
            color: var(--color-global-text);
        }

        .cactus-content .kg-bookmark-card .kg-bookmark-content,
        .kg-bookmark-card.lv-atproto-card .kg-bookmark-content,
        .now-status-entry__body .kg-bookmark-card .kg-bookmark-content {
            min-width: 0;
            padding: 0;
            background: transparent;
        }

        .cactus-content .kg-bookmark-card .kg-bookmark-thumbnail,
        .kg-bookmark-card.lv-atproto-card .kg-bookmark-thumbnail,
        .now-status-entry__body .kg-bookmark-card .kg-bookmark-thumbnail {
            display: block;
            min-width: 0;
            min-height: 5rem;
            overflow: hidden;
            border-radius: 0.4rem;
            background: transparent;
            opacity: 1;
        }

        .cactus-content .kg-bookmark-card .kg-bookmark-thumbnail img,
        .kg-bookmark-card.lv-atproto-card .kg-bookmark-thumbnail img,
        .now-status-entry__body .kg-bookmark-card .kg-bookmark-thumbnail img {
            display: block;
            width: 100%;
            height: 100%;
            min-height: 5rem;
            border-radius: 0;
            object-fit: cover;
            opacity: 1;
            visibility: visible;
            transform: none;
        }

        @media (max-width: 520px) {
            .cactus-content .kg-bookmark-card a.kg-bookmark-container,
            .cactus-content .kg-bookmark-card a.kg-bookmark-container:hover,
            .kg-bookmark-card.lv-atproto-card a.kg-bookmark-container,
            .kg-bookmark-card.lv-atproto-card a.kg-bookmark-container:hover,
            .now-status-entry__body .kg-bookmark-card a.kg-bookmark-container,
            .now-status-entry__body .kg-bookmark-card a.kg-bookmark-container:hover {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body class="{{body_class}}">
    <a class="skip-link" href="#main">{{t "Skip to content"}}</a>

    <div class="cactus-shell">
        <header class="cactus-header cactus-header-no-logo" id="main-header">
            <div class="cactus-brand-wrap">
                <a class="cactus-brand" href="{{@site.url}}" aria-label="{{@site.title}}">
                    <span class="cactus-brand-title">{{@site.title}} <span aria-hidden="true">//</span></span>
                </a>

                <nav class="cactus-nav" id="navigation-menu" aria-label="{{t "Main menu"}}">
                    {{navigation}}
                </nav>
            </div>

            <div class="cactus-actions">
                <button class="cactus-icon-button" type="button" aria-label="{{t "Search this site"}}" data-ghost-search>
                    {{> "icons/search"}}
                </button>
                <button class="cactus-icon-button" type="button" aria-label="{{t "Toggle color theme"}}" data-theme-toggle>
                    <span class="theme-icon theme-icon-dark">{{> "icons/moon"}}</span>
                    <span class="theme-icon theme-icon-light">{{> "icons/sun"}}</span>
                </button>
                <button class="cactus-icon-button cactus-menu-toggle" type="button" aria-label="{{t "Toggle menu"}}" aria-expanded="false" aria-controls="navigation-menu" data-menu-toggle></button>
            </div>
        </header>

        <main class="cactus-main" id="main">
            {{{body}}}
        </main>

        <footer class="cactus-footer">
            <nav class="cactus-footer-nav" aria-label="{{t "More on this site"}}">
                {{navigation type="secondary"}}
            </nav>
            <div class="cactus-copyright">
                &copy; {{@site.title}} {{date format="YYYY"}}.
            </div>
        </footer>
    </div>

    {{> "pswp"}}

    <script
        src="https://code.jquery.com/jquery-3.5.1.min.js"
        integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
        crossorigin="anonymous">
    </script>
    <script src="{{asset "built/main.min.js"}}"></script>

    {{ghost_foot}}
</body>
</html>
