{{!< default}}

<header class="archive-header">
    <h1 class="cactus-title">Notes</h1>
    <p>Short observations, status posts, and smaller updates.</p>
</header>

<section class="cactus-section archive-section">
    <ul class="note-list" role="list">
        {{#foreach posts}}
            {{> "note-preview"}}
        {{else}}
            <li>No notes are published yet.</li>
        {{/foreach}}
    </ul>
    {{pagination}}
</section>
