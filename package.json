{
    "name": "cactus-lowvelocity",
    "description": "A Cactus-inspired Ghost theme for Low Velocity",
    "version": "1.0.0",
    "private": true,
    "engines": {
        "ghost": ">=5.0.0"
    },
    "license": "MIT",
    "author": {
        "name": "Bryan Robb",
        "email": "bryan.robb@icloud.com",
        "url": "https://bryanrobb.com"
    },
    "keywords": [
        "ghost",
        "theme",
        "ghost-theme"
    ],
    "docs": "https://lowvelocity.org/about/",
    "config": {
        "posts_per_page": 10,
        "image_sizes": {
            "xs": {
                "width": 150
            },
            "s": {
                "width": 300
            },
            "m": {
                "width": 750
            },
            "l": {
                "width": 1140
            },
            "xl": {
                "width": 1920
            }
        },
        "card_assets": true,
        "custom": {
            "color_scheme": {
                "type": "select",
                "options": [
                    "Auto",
                    "Light",
                    "Dark"
                ],
                "default": "Auto"
            },
            "content_width": {
                "type": "select",
                "options": [
                    "400px",
                    "450px",
                    "500px",
                    "550px",
                    "600px",
                    "650px",
                    "700px"
                ],
                "default": "550px",
                "description": "Maximum desktop width; mobile remains fluid"
            },
            "header_font_weight": {
                "type": "select",
                "options": [
                    "Regular",
                    "Medium",
                    "Semibold",
                    "Bold",
                    "Extra Bold",
                    "Black"
                ],
                "default": "Bold",
                "description": "Weight of the site title"
            },
            "navigation_font_weight": {
                "type": "select",
                "options": [
                    "Regular",
                    "Medium",
                    "Semibold",
                    "Bold"
                ],
                "default": "Medium",
                "description": "Weight of header and footer navigation links"
            },
            "body_font": {
                "type": "select",
                "options": [
                    "Ghost typography",
                    "Roboto Mono",
                    "IBM Plex Mono"
                ],
                "default": "Ghost typography",
                "description": "Font used for articles and general site text"
            },
            "body_font_style": {
                "type": "select",
                "options": [
                    "Normal",
                    "Italic"
                ],
                "default": "Normal",
                "description": "Style used for articles and general site text"
            },
            "bluesky_handle": {
                "type": "text",
                "default": "lowvelocity.org",
                "description": "Bluesky account shown in the homepage Notes feed"
            },
            "light_mode_background_color": {
                "type": "color",
                "default": "#ffffff",
                "description": "Page background in light mode"
            },
            "light_mode_text_color": {
                "type": "color",
                "default": "#3d4044",
                "description": "Body text and headings in light mode"
            },
            "light_mode_accent_color": {
                "type": "color",
                "default": "#d45478",
                "description": "Links, navigation accents, and quotes in light mode"
            },
            "dark_mode_background_color": {
                "type": "color",
                "default": "#171717",
                "description": "Page background in dark mode"
            },
            "dark_mode_text_color": {
                "type": "color",
                "default": "#e2e2e2",
                "description": "Body text and headings in dark mode"
            },
            "dark_mode_accent_color": {
                "type": "color",
                "default": "#2abc89",
                "description": "Links, navigation accents, and quotes in dark mode"
            },
            "use_separate_mode_accent_colors": {
                "type": "boolean",
                "default": false,
                "description": "Override the Brand accent with separate light and dark accents"
            },
            "show_related_posts": {
                "type": "boolean",
                "default": true,
                "group": "post"
            },
            "related_posts_title": {
                "type": "text",
                "default": "You might also like...",
                "group": "post"
            }
        }
    },
    "scripts": {
        "dev": "gulp",
        "test": "gscan .",
        "zip": "gulp zip"
    },
    "devDependencies": {
        "@tryghost/shared-theme-assets": "2.7.1",
        "@tryghost/theme-translations": "^0.0.9",
        "autoprefixer": "10.5.0",
        "beeper": "2.1.0",
        "cssnano": "8.0.1",
        "gscan": "6.2.1",
        "gulp": "5.0.1",
        "gulp-concat": "2.6.1",
        "gulp-livereload": "4.0.2",
        "gulp-postcss": "10.0.0",
        "gulp-uglify": "3.0.2",
        "gulp-zip": "5.1.0",
        "ordered-read-streams": "2.0.0",
        "postcss": "8.5.15",
        "postcss-easy-import": "4.0.0",
        "pump": "3.0.4"
    }
}
