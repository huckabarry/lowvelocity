{{#get "posts" limit="5" filter="tags:[{{post.tags}}]+id:-{{post.id}}" as |related|}}
{{#if related}}
    <section class="related-posts">
        {{#if @custom.related_posts_title}}
            <h3 class="related-title">{{@custom.related_posts_title}}</h3>
        {{/if}}
        <ul class="post-list" role="list">
            {{#foreach posts}}
                {{> "post-preview"}}
            {{/foreach}}
        </ul>
    </section>
{{/if}}
{{/get}}
