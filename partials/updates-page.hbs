{{#post}}
<header class="archive-header updates-header">
    <h1 class="cactus-title">{{title}}</h1>
    {{#if custom_excerpt}}
        <p>{{custom_excerpt}}</p>
    {{else}}
        <p>Status updates, listening notes, check-ins, books, movies, and shows folded into one running stream.</p>
    {{/if}}
    <div class="cactus-content updates-intro">
        {{content}}
    </div>
</header>
{{/post}}

<section
    class="mixed-feed updates-mixed-feed"
    aria-label="{{t "Updates feed"}}"
    data-now-status-filter="tag:hash-bluesky"
    data-now-status-limit="100"
    data-now-listening-filter="tag:hash-crucialtracks"
    data-now-listening-limit="25"
    data-now-checkins-filter="tag:check-ins"
    data-now-checkins-limit="50"
    data-now-popfeed-filter="tag:hash-popfeed"
    data-now-popfeed-limit="50"
    data-now-feed>
    <div class="mixed-feed__items" data-now-feed-items aria-live="polite">
        <p class="now-feed-status">{{t "Loading updates…"}}</p>
    </div>

    {{#get "posts" filter="tag:hash-crucialtracks" limit="25" include="tags" order="published_at desc" formats="html" as |tracks|}}
        {{#foreach tracks}}
            <template
                data-now-listening-entry
                data-date="{{date published_at format="YYYY-MM-DDTHH:mm:ss.SSSZ"}}"
                data-date-label="{{date published_at format="MMM D, YYYY"}}"
                data-title="{{title}}"
                data-url="{{url}}"
                data-image="{{#if feature_image}}{{img_url feature_image size="s"}}{{/if}}"
                data-image-alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                data-summary="{{custom_excerpt}}">
                {{content}}
            </template>
        {{/foreach}}
    {{/get}}

    {{#get "posts" filter="tag:hash-bluesky" limit="100" include="tags" order="published_at desc" formats="html" as |statuses|}}
        {{#foreach statuses}}
            <template
                data-now-status-entry
                data-date="{{date published_at format="YYYY-MM-DDTHH:mm:ss.SSSZ"}}"
                data-date-label="{{date published_at format="MMM D, YYYY"}}"
                data-title="{{title}}"
                data-url="{{url}}">
                {{content}}
            </template>
        {{/foreach}}
    {{/get}}

    {{#get "posts" filter="tag:hash-popfeed" limit="50" include="tags" order="published_at desc" formats="html" as |media_items|}}
        {{#foreach media_items}}
            <template
                data-now-popfeed-entry
                data-date="{{date published_at format="YYYY-MM-DDTHH:mm:ss.SSSZ"}}"
                data-date-label="{{date published_at format="MMM D, YYYY"}}"
                data-title="{{title}}"
                data-url="{{url}}"
                data-image="{{#if feature_image}}{{img_url feature_image size="s"}}{{/if}}"
                data-image-alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                data-summary="{{custom_excerpt}}">
                {{content}}
            </template>
        {{/foreach}}
    {{/get}}

    {{#get "posts" filter="tag:check-ins" limit="50" include="tags" order="published_at desc" formats="html" as |checkins|}}
        {{#foreach checkins}}
            <template
                data-now-checkin-entry
                data-date="{{date published_at format="YYYY-MM-DDTHH:mm:ss.SSSZ"}}"
                data-date-label="{{date published_at format="MMM D, YYYY"}}"
                data-title="{{title}}"
                data-url="{{url}}">
                {{content}}
            </template>
        {{/foreach}}
    {{/get}}
</section>
